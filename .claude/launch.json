{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "waitcost-dashboard",
      "runtimeExecutable": ".venv/bin/streamlit",
      "runtimeArgs": ["run", "app/dashboard.py", "--server.headless", "true", "--server.port", "8501"],
      "port": 8501
    },
    {
      "name": "waitcost-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 5173
    },
    {
      "name": "waitcost-app",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["api.main:app", "--host", "0.0.0.0", "--port", "7860"],
      "port": 7860,
      "env": { "WAITCOST_PLANNER": "rule", "FRONTEND_DIST": "frontend/dist" }
    }
  ]
}
