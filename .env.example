# Copy to `.env` and adjust as needed: `cp .env.example .env`

# Planner mode:
#   gemma = always use Gemma via Ollama (this is what you want in the cloud)
#   auto  = try Gemma, silently fall back to deterministic rule-mode if Ollama is down
#   rule  = deterministic only, no LLM (cheapest / can't-fail)
WAITCOST_PLANNER=gemma

# Gemma model tag pulled into Ollama and used by the planner/narrator.
#   gemma3n:e2b -> smaller, runs on CPU with ~4-6 GB RAM (recommended)
#   gemma3n:e4b -> larger/better, needs ~8-10 GB RAM
GEMMA_MODEL=gemma3n:e2b

# Seconds the backend waits for a Gemma response (CPU inference is slower).
GEMMA_TIMEOUT=60
