# Copy to `.env` and adjust as needed: `cp .env.example .env`
# `.env` is gitignored — never commit your API key.

# Planner / narrator mode:
#   claude = always use Claude Sonnet 4.6 via the Anthropic API (needs ANTHROPIC_API_KEY)
#   auto   = use Claude when a key is present, silently fall back to rule-mode otherwise
#   rule   = deterministic only, no LLM, no network (cheapest / air-gapped / can't-fail)
WAITCOST_PLANNER=claude

# Anthropic API key for the Claude planner/narrator. Env-only — never commit it.
ANTHROPIC_API_KEY=

# Agentic reasoning mode (Phase 2):
#   single  = one-shot planner (default)
#   toolloop = Claude orchestrates the engine over multiple tool calls
WAITCOST_AGENT=single

# Optional: pin a different Claude model, or widen the request timeout (seconds).
# WAITCOST_CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_TIMEOUT=30
