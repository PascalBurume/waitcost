# WaitCost backend (FastAPI) — used by docker-compose.yml (server + Ollama/Gemma stack).
# For the cheap single-service Hugging Face deploy, see the root ./Dockerfile instead.
# Serves the engine on :8000; frontend (nginx) reverse-proxies /api/* to this service.
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# Install deps first for better layer caching.
COPY requirements.txt ./
RUN pip install --upgrade pip && pip install -r requirements.txt

# Copy application code (see .dockerignore for what's excluded).
COPY . .

EXPOSE 8000

# Gemma planner talks to the Ollama service over the compose network.
# Override these in docker-compose.yml / .env.
ENV WAITCOST_PLANNER=gemma \
    OLLAMA_HOST=http://ollama:11434 \
    GEMMA_MODEL=gemma3n:e2b

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
